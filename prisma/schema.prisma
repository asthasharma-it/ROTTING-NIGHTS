generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  name              String?
  email             String?   @unique
  emailVerified     DateTime?
  image             String?
  hasCompletedQuiz  Boolean   @default(false)

  accounts          Account[]
  sessions          Session[]
  watchStatuses     WatchStatus[]
  ratings           Rating[]
  episodeProgress   EpisodeProgress[]
  quizAnswers       QuizAnswer[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum WatchStatusType {
  NOPE
  MAYBE
  DEFINITELY
  ONGOING
  WATCHED
}

enum MediaType {
  movie
  tv
}

model WatchStatus {
  id        String          @id @default(cuid())
  userId    String
  tmdbId    Int
  mediaType MediaType
  status    WatchStatusType
  title     String
  posterPath String?
  updatedAt DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tmdbId, mediaType])
}

model Rating {
  id        String    @id @default(cuid())
  userId    String
  tmdbId    Int
  mediaType MediaType
  score     Int
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tmdbId, mediaType])
}

model EpisodeProgress {
  id        String    @id @default(cuid())
  userId    String
  tmdbId    Int
  season    Int
  episode   Int
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tmdbId])
}

model QuizAnswer {
  id        String   @id @default(cuid())
  userId    String
  question  String
  answer    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, question])
}
